@page "/not-found"
@layout MainLayout
@inject NavigationManager NavManager

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center justify-center" Style="height: 80vh;">
    <MudIcon Icon="@Icons.Material.Filled.CloudOff" Color="Color.Error" Style="font-size: 120px;" Class="mb-4"/>

    <MudText Typo="Typo.h2" Align="Align.Center" Color="Color.Primary" Class="mb-2" Style="font-weight: 700;">
        404
    </MudText>

    <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">
        Похоже, вы заблудились в облаках...
    </MudText>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               Size="Size.Large"
               OnClick="@GoHome"
               StartIcon="@Icons.Material.Filled.Home"
               DisableElevation="true"
               Class="rounded-pill px-6 py-2">
        Вернуться
    </MudButton>
</MudContainer>

@code {

    private void GoHome()
    {
        NavManager.NavigateTo("/");
    }

}