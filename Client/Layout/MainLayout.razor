@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="true"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudHidden Breakpoint="Breakpoint.MdAndUp">
    <div class="d-flex flex-column align-center justify-center pa-6" style="height: 100vh; background-color: var(--mud-palette-background);">
        <MudIcon Icon="@Icons.Material.Filled.DesktopMac" Size="Size.Large" Color="Color.Primary" Class="mb-4"/>
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-2">
            Сайт оптимизирован для ПК и горизонтального просмотра
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
            Пожалуйста, откройте его на компьютере или включите <strong>«Версию для ПК»</strong> в настройках мобильного браузера.
        </MudText>
    </div>
</MudHidden>

<MudHidden Breakpoint="Breakpoint.SmAndDown">
    <MudLayout>
        <MudAppBar Elevation="1">
            <MudText Typo="Typo.h5" Class="ml-3">ClashStats</MudText>
            <MudSpacer/>
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.End" OnClick="@ToggleDrawer"/>
        </MudAppBar>

        <MudDrawer @bind-Open="@_drawerOpen" Anchor="Anchor.End" Elevation="1" Variant="@DrawerVariant.Responsive">
            <MudDrawerHeader>
                <MudText Typo="Typo.h6">Меню</MudText>
            </MudDrawerHeader>

            <NavMenu/>
        </MudDrawer>

        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4 pt-4">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
</MudHidden>

@code {
    bool _drawerOpen = true;

    void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

}