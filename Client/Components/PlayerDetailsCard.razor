@using Client.ViewModels
<MudCard Elevation="0">
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true">

        <MudTabPanel Text="Сводка профиля" Class="pa-4">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.TrendingUp">Трофеи: <strong>@Player.Member.Trophies</strong></MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Star">Звезд в КВ (всего): <strong>@Player.Member.WarStars</strong></MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.HomeWork">Деревня строителя:
                            <strong>ТХ @Player.Member.BuilderHallLevel (@Player.Member.BuilderBaseTrophies)</strong></MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.MilitaryTech">Уровень: <strong>@Player.Member.ExpLevel</strong></MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Handshake">Вклад в Столицу: <strong>@Player.Member.ClanCapitalContributions</strong>
                        </MudListItem>
                    </MudList>
                </MudItem>
                <MudItem xs="12" md="8">
                    <div class="d-flex flex-column align-center w-100 h-100 justify-center">
                        <MudText Typo="Typo.subtitle2" Class="mb-4" Align="Align.Center">Динамика доната (последние сезоны)</MudText>

                        @switch (Player.DonationHistoryValues.Length)
                        {
                            case > 1:
                                <MudChart ChartType="ChartType.Line"
                                          ChartSeries="@Player.DonationChartSeries"
                                          ChartLabels="@Player.DonationHistoryLabels"
                                          Width="100%" Height="250px"/>
                                break;
                            case 1:
                                <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined" Class="mt-2 mx-auto" Style="max-width: 400px;">
                                    Данных для графика пока недостаточно.
                                    <br/>
                                    Записан 1 сезон: <strong>@Player.DonationHistoryValues[0]</strong> ед. доната.
                                </MudAlert>
                                break;
                            default:
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">Нет исторических данных по донату</MudText>
                                break;
                        }
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Обычные КВ" Class="pa-4">
            @if (Player.CwSummary is not null)
            {
                <MudGrid>
                    <MudItem xs="12" md="6" Class="pb-0">
                        <MudList T="string" Dense="true">
                            <MudListItem T="string">Средний снос: <strong>@Player.CwSummary.AverageDestructionPercentage.ToString("0.##")%</strong></MudListItem>
                            <MudListItem T="string">Звезд за атаку: <strong>@Player.CwSummary.AverageStarsPerAttack.ToString("0.##")</strong></MudListItem>
                            <MudListItem T="string">Звезд за войну: <strong>@Player.CwSummary.AverageStarsPerWar.ToString("0.##")</strong></MudListItem>
                            <MudListItem T="string">Дисбаланс ТХ: <strong>@Player.CwSummary.AverageThMismatches.ToString("+0.##;-0.##;0")</strong></MudListItem>
                        </MudList>
                    </MudItem>

                    <MudItem xs="12" md="6" Class="pb-0">
                        <MudList T="string" Dense="true">
                            <MudListItem T="string">Использование 1-й атаки: <strong>@Player.CwSummary.FirstAttackParticipationRate.ToString("0.##")%</strong></MudListItem>
                            <MudListItem T="string">Использование 2-й атаки: <strong>@Player.CwSummary.SecondAttackParticipationRate.ToString("0.##")%</strong></MudListItem>
                            <MudListItem T="string">Атаки по зеркалу: <strong>@Player.CwSummary.MirrorAttacksRate.ToString("0.##")%</strong></MudListItem>
                            <MudListItem T="string">3★ против своего уровня ТХ: <strong>@Player.CwSummary.ThreeStarRateAgainstSameTh.ToString("0.##")%</strong></MudListItem>
                        </MudList>
                    </MudItem>

                    <MudItem xs="12" Class="pt-0">
                        <MudList T="string" Dense="true" Class="pt-0">
                            <MudListItem T="string">
                                <div class="d-flex align-center gap-2">
                                    <span>История последних 5 КВ (активность атак):</span>
                                    @if (Player.CwSummary.RecentWarsAttacks.Count > 0)
                                    {
                                        @foreach (var atk in Player.CwSummary.RecentWarsAttacks)
                                        {
                                            <MudChip T="short" Size="Size.Small" Color="@GetCwAttackColor(atk)">@atk
                                                @(atk switch
                                                {
                                                    1 => "атака",
                                                    2 => "атаки",
                                                    _ => "атак"
                                                })
                                            </MudChip>
                                        }
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Нет недавних участий</MudText>
                                    }
                                </div>
                            </MudListItem>
                        </MudList>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">Нет накопленной аналитики по КВ</MudText>
            }
        </MudTabPanel>

        <MudTabPanel Text="Лига Клановых Войн" Class="pa-4">
            @if (Player.LatestCwlSummary is not null)
            {
                <MudText Typo="Typo.subtitle1" Class="mb-2 px-4 mt-2">Данные за актуальный сезон: <strong>@Player.LatestCwlSummary.Season</strong></MudText>

                <MudGrid>
                    <MudItem xs="12" md="6" Class="pb-0">
                        <MudList T="string" Dense="true">
                            <MudListItem T="string">Дней выставлен на карту: <strong>@Player.LatestCwlSummary.TotalRoundsOnMap из 7</strong></MudListItem>
                            <MudListItem T="string">Средний снос: <strong>@Player.LatestCwlSummary.AverageDestructionPercentage.ToString("0.##")%</strong></MudListItem>
                            <MudListItem T="string">Звезд за атаку: <strong>@Player.LatestCwlSummary.AverageStarsPerAttack.ToString("0.##")</strong></MudListItem>
                        </MudList>
                    </MudItem>

                    <MudItem xs="12" md="6" Class="pb-0">
                        <MudList T="string" Dense="true">
                            <MudListItem T="string">Дисбаланс ТХ: <strong>@Player.LatestCwlSummary.AverageThMismatches.ToString("+0.##;-0.##;0")</strong></MudListItem>
                            <MudListItem T="string">Атаки по зеркалу: <strong>@Player.LatestCwlSummary.MirrorAttacksRate.ToString("0.##")%</strong></MudListItem>
                            <MudListItem T="string">3★ против своего уровня ТХ: <strong>@Player.LatestCwlSummary.ThreeStarRateAgainstSameTh.ToString("0.##")%</strong></MudListItem>
                        </MudList>
                    </MudItem>

                    <MudItem xs="12" Class="pt-0">
                        <MudList T="string" Dense="true" Class="pt-0">
                            <MudListItem T="string">
                                <div class="d-flex align-center gap-2">
                                    <span>Результаты раундов недели ЛВК:</span>
                                    @if (Player.LatestCwlSummary.CwlRoundsAttacks.Count > 0)
                                    {
                                        @foreach (var round in Player.LatestCwlSummary.CwlRoundsAttacks)
                                        {
                                            <MudAvatar Size="Size.Small" Color="@GetCwlRoundColor(round)" Style="width: 24px; height: 24px; font-size: 0.75rem;">
                                                @GetCwlRoundText(round)
                                            </MudAvatar>
                                        }
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">История раундов пуста</MudText>
                                    }
                                </div>
                            </MudListItem>
                        </MudList>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">Игрок не принимал участие в ЛВК</MudText>
            }
        </MudTabPanel>

    </MudTabs>
</MudCard>

@code {
    [Parameter] public FullPlayerViewModel Player { get; set; } = default!;

    private static Color GetCwAttackColor(short attacks) => attacks switch
    {
        2 => Color.Success,
        1 => Color.Warning,
        0 => Color.Error,
        _ => Color.Default
    };

    private static Color GetCwlRoundColor(short result) => result switch
    {
        3 => Color.Success,
        2 or 1 => Color.Warning,
        0 => Color.Error,
        -1 => Color.Info,
        _ => Color.Surface
    };

    private static string GetCwlRoundText(short result) => result switch
    {
        >= 0 => result.ToString(),
        -1 => "Z",
        _ => "-"
    };

}